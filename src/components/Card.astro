---
import type { HTMLAttributes } from 'astro/types';
import { type BrutalVariant } from '../config';
import { cn, resolveColor } from '../utils/styles';

interface Props extends HTMLAttributes<'div'> {
  color?: string;
  variant?: BrutalVariant;
  padded?: boolean;
  interactive?: boolean;
}

const {
  color: customColor,
  variant = 'neutral',
  padded = true,
  interactive = false,
  class: className,
  ...rest
} = Astro.props;

const color = resolveColor(customColor, variant, 'neutral');
const classes = cn(
  'brutal-card',
  padded && 'brutal-card--padded',
  interactive && 'brutal-card--interactive',
  className,
);
---

<style define:vars={{ color: color }}>
  div.brutal-card {
    background-color: var(--color);
    border-radius: 0.5rem;
    border: 3px solid black;
    box-shadow: 7px 7px 0 rgb(0 0 0 / 1);
    color: black;
    transition:
      transform 150ms ease,
      box-shadow 150ms ease,
      background-color 150ms ease;
  }

  div.brutal-card--padded {
    padding: 1rem;
  }

  div.brutal-card--interactive:hover {
    box-shadow: 5px 5px 0 rgb(0 0 0 / 1);
  }

  div.brutal-card--interactive:focus-within {
    outline: 3px solid black;
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    div.brutal-card {
      transition: none;
    }
  }
</style>

<div {...rest} class={classes}>
  <slot />
</div>
