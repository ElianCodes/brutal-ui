---
import type { HTMLAttributes } from 'astro/types';
import { type BrutalSize, type BrutalVariant } from '../config';
import { cn, resolveColor } from '../utils/styles';

interface Props extends HTMLAttributes<'span'> {
  color?: string;
  variant?: BrutalVariant;
  size?: BrutalSize;
}

const {
  color: customColor,
  variant = 'accent',
  size = 'md',
  class: className,
  ...rest
} = Astro.props;

const color = resolveColor(customColor, variant, 'accent');
const classes = cn('brutal-pill', `brutal-pill--${size}`, className);
---

<style define:vars={{ color: color }}>
  span.brutal-pill {
    filter: drop-shadow(3px 3px 0 rgb(0 0 0 / 1));
    user-select: none;
    background-color: white;
    color: black;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    border-radius: 9999px;
    border: 2px solid black;
    padding: 0.25rem 0.75rem;
    transition:
      transform 150ms ease,
      filter 150ms ease,
      background-color 150ms ease;
    font-size: small;
    font-weight: 700;
    white-space: nowrap;
  }

  span.brutal-pill--sm {
    padding: 0.2rem 0.625rem;
    font-size: 0.75rem;
  }

  span.brutal-pill--md {
    font-size: 0.875rem;
  }

  span.brutal-pill--lg {
    padding: 0.375rem 0.875rem;
    font-size: 1rem;
  }

  span.brutal-pill:hover {
    filter: drop-shadow(5px 5px 0 rgb(0 0 0 / 1));
    background-color: var(--color);
  }

  span.brutal-pill:focus-visible {
    outline: 3px solid black;
    outline-offset: 3px;
  }

  @media (prefers-reduced-motion: reduce) {
    span.brutal-pill {
      transition: none;
    }
  }
</style>

<span {...rest} class={classes}>
  <slot />
</span>
