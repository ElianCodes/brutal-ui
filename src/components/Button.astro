---
import type { HTMLAttributes } from 'astro/types';
import { type BrutalSize, type BrutalVariant } from '../config';
import { cn, resolveColor } from '../utils/styles';

interface Props extends HTMLAttributes<'a'> {
  color?: string;
  variant?: BrutalVariant;
  size?: BrutalSize;
  fullWidth?: boolean;
}

const {
  color: customColor,
  variant = 'primary',
  size = 'md',
  fullWidth = false,
  class: className,
  ...rest
} = Astro.props;

const color = resolveColor(customColor, variant, 'primary');
const classes = cn('brutal-btn', `brutal-btn--${size}`, fullWidth && 'brutal-btn--full', className);
---

<style define:vars={{ color: color }}>
  a.brutal-btn {
    box-shadow: 5px 5px 0 rgb(0 0 0 / 1);
    background-color: white;
    color: black;
    display: inline-flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;
    width: fit-content;
    padding: 0.5rem 1rem;
    border: 2px solid black;
    text-decoration: none;
    font-family: var(--brutal-font-family, 'Sanchez', ui-serif, Georgia, serif);
    font-weight: 700;
    line-height: 1.2;
    transition:
      transform 150ms ease,
      box-shadow 150ms ease,
      background-color 150ms ease;
  }

  a.brutal-btn--sm {
    padding: 0.375rem 0.75rem;
    font-size: 0.875rem;
  }

  a.brutal-btn--md {
    font-size: 1rem;
  }

  a.brutal-btn--lg {
    padding: 0.75rem 1.25rem;
    font-size: 1.125rem;
  }

  a.brutal-btn--full {
    width: 100%;
  }

  a.brutal-btn:hover {
    box-shadow: 3px 3px 0 rgb(0 0 0 / 1);
    background-color: var(--color);
  }

  a.brutal-btn:focus-visible {
    outline: 3px solid black;
    outline-offset: 3px;
    background-color: var(--color);
  }

  a.brutal-btn:active {
    transform: translate(2px, 2px);
    box-shadow: 1px 1px 0 rgb(0 0 0 / 1);
  }

  a.brutal-btn[aria-disabled='true'] {
    cursor: not-allowed;
    opacity: 0.65;
    pointer-events: none;
    box-shadow: none;
  }

  @media (prefers-reduced-motion: reduce) {
    a.brutal-btn {
      transition: none;
    }
  }
</style>

<a {...rest} class={classes}>
  <slot />
</a>
